generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionTier {
  FREE
  PRO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum UserRole {
  USER
  ADMIN
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String           @id @default(uuid())
  supabaseId   String?          @unique
  email        String           @unique
  password     String?
  name         String?
  role         UserRole         @default(USER)
  subscription SubscriptionTier @default(FREE)
  dailyUsage   Int              @default(0)
  lastUsageReset DateTime       @default(now())
  banned       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  analyses Analysis[]
  payments Payment[]
}

model Analysis {
  id            String   @id @default(uuid())
  jobId         String   @unique
  userId        String
  imageUrl      String
  pair          String
  timeframe     String
  assetClass    String?
  status        AnalysisStatus @default(QUEUED)
  progress      Int      @default(0)
  currentStage  String?
  bias          String?
  entry         Float?
  stopLoss      Float?
  tp1           Float?
  tp2           Float?
  takeProfits   Json?
  confidence    Int?
  explanation   String?
  analysisText  String?
  strategy      String?
  structure     Json?
  waitConditions String?
  rawResponse   Json?
  layer1Output  Json?
  layer2Output  Json?
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  paypalOrderId String        @unique
  amount        Float
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  plan          SubscriptionTier
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PricingPlan {
  id          String           @id @default(uuid())
  name        String
  tier        SubscriptionTier @unique
  price       Float
  features    Json
  dailyLimit  Int
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
