{
  "name": "chartmind-ai-backend",
  "version": "1.0.0",
  "description": "ChartMind AI Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/analysisWorker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/workers/analysisWorker.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "bullmq": "^5.16.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.29.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
